@page "/login"
@layout LoginLayout

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h2>InversionesZJ</h2>
            <p>Ingresa tus credenciales</p>
        </div>

        <div class="login-body">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-error">
                    @errorMessage
                </div>
            }

            <EditForm Model="Input" OnValidSubmit="HandleLogin" FormName="login" method="post">
                <div class="form-group">
                    <label>Usuario</label>
                    <InputText @bind-Value="Input.Username" class="form-control" placeholder="Ingresa tu usuario" />
                </div>

                <div class="form-group">
                    <label>Contraseña</label>
                    <InputText type="password" @bind-Value="Input.Password" class="form-control" placeholder="Ingresa tu contraseña" />
                </div>

                <button type="submit" class="btn-login">
                    <span>Ingresar</span>
                </button>
            </EditForm>

            <div class="forgot-link">
                <a href="/forgot-password">¿Olvidaste tu contraseña?</a>
            </div>
        </div>
    </div>
</div>
