      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\InversionesZJ.Application\InversionesZJ.Application.csproj" />
    <ProjectReference Include="..\InversionesZJ.Infrastructure\InversionesZJ.Infrastructure.csproj" />
  </ItemGroup>

</Project>
