@using Microsoft.AspNetCore.Components.Authorization

<header class="app-topbar">
    <div class="topbar-left">
        <!-- espacio para título de página o buscador a futuro -->
    </div>

    <div class="topbar-right">
        <AuthorizeView>
            <Authorized>
                <div class="topbar-user">
                    <div class="user-avatar">
                        @GetInitials(context.User.Identity?.Name)
                    </div>
                    <div class="user-info">
                        <span class="user-name">@context.User.FindFirst("FullName")?.Value</span>
                        <span class="user-role">@context.User.Identity?.Name</span>
                    </div>
                </div>

                <form action="/logout" method="post">
                    <AntiforgeryToken />
                    <button type="submit" class="btn-logout" title="Cerrar sesión">
                        Salir
                    </button>
                </form>
            </Authorized>
        </AuthorizeView>
    </div>
</header>

@code {
    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        return name.Length >= 2 ? name.Substring(0, 2).ToUpper() : name.ToUpper();
    }
}