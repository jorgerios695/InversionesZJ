@page "/login"
@using InversionesZJ.Web.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h2>InversionesZJ</h2>
            <p>Ingresa tus credenciales</p>
        </div>

        <div class="login-body">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-error">
                    @errorMessage
                </div>
            }

            <div class="form-group">
                <label>Usuario</label>
                <input type="text" @bind="username" placeholder="Ingresa tu usuario" />
            </div>

            <div class="form-group">
                <label>Contraseña</label>
                <input type="password" @bind="password" placeholder="Ingresa tu contraseña" />
            </div>

            <button class="btn-login" @onclick="HandleLogin">
                @if (isLoading)
                {
                    <span>Cargando...</span>
                }
                else
                {
                    <span>Ingresar</span>
                }
            </button>
        </div>
    </div>
</div>

@code {
    private string username = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        errorMessage = string.Empty;
        isLoading = true;

        try
        {
            var response = await AuthService.LoginAsync(username, password);

            if (response.Success)
            {
                Navigation.NavigateTo("/");
            }
            else
            {
                if (response.ResponseCode == "400")
                    Console.WriteLine("Te devolvi 400");
                errorMessage = response.ResponseMessage;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}