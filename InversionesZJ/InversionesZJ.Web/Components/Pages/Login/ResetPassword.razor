@page "/reset-password"
@layout LoginLayout
@rendermode InteractiveServer

<div class="login-card">
    <div class="login-header">
        <h2>InversionesZJ</h2>
        <p>Nueva contraseña</p>
    </div>

    <div class="login-body">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert-info">@successMessage</div>
        }

        @if (!isDone)
        {
            <div class="form-group">
                <label>Nueva contraseña</label>
                <input type="password" @bind="newPassword" placeholder="Ingresa tu nueva contraseña" />
            </div>

            <div class="form-group">
                <label>Confirmar contraseña</label>
                <input type="password" @bind="confirmPassword" placeholder="Confirma tu contraseña" />
            </div>

            <button class="btn-login" @onclick="HandleReset" disabled="@isLoading">
                @if (isLoading)
                {
                    <span>Guardando...</span>
                }
                else
                {
                    <span>Cambiar contraseña</span>
                }
            </button>
        }

        <div class="forgot-link">
            <a href="/login">Volver al inicio de sesión</a>
        </div>
    </div>
</div>
